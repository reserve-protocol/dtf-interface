{
  "name": "@dtf-interface/sdk",
  "version": "0.0.0",
  "description": "Core TypeScript SDK for DTF interface integrations.",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist *.tsbuildinfo",
    "dev": "tsc -p tsconfig.build.json --watch --preserveWatchOutput",
    "graphql:codegen": "graphql-codegen --config codegen.yml",
    "playground:index": "tsx playground/index-dtf.ts",
    "prebuild": "pnpm --filter @dtf-interface/dtf-catalog build && pnpm --filter @reserve-protocol/dtf-rebalance-lib build && pnpm run clean",
    "pretest": "pnpm --filter @dtf-interface/dtf-catalog build && pnpm --filter @reserve-protocol/dtf-rebalance-lib build",
    "pretypecheck": "pnpm --filter @dtf-interface/dtf-catalog build && pnpm --filter @reserve-protocol/dtf-rebalance-lib build",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@dtf-interface/dtf-catalog": "workspace:*",
    "@reserve-protocol/dtf-rebalance-lib": "workspace:*",
    "@graphql-typed-document-node/core": "^3.2.0",
    "decimal.js-light": "^2.5.1",
    "graphql": "^16.13.2",
    "graphql-request": "^7.4.0",
    "viem": "^2.48.0",
    "zod": "^4.4.2"
  },
  "keywords": [
    "dtf",
    "sdk",
    "typescript"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.19"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^6.3.1",
    "@graphql-codegen/typed-document-node": "^6.1.8",
    "@graphql-codegen/typescript": "^5.0.10",
    "@graphql-codegen/typescript-operations": "^5.1.0",
    "tsx": "^4.21.0"
  }
}
