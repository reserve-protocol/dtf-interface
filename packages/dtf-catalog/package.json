{
  "name": "@dtf-interface/dtf-catalog",
  "version": "0.0.0",
  "private": true,
  "description": "Curated DTF catalog for yield and index DTFs.",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "index-dtf",
    "yield-dtf",
    "images"
  ],
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./images/*": "./images/*",
    "./index-dtf/*": "./index-dtf/*",
    "./yield-dtf/*": "./yield-dtf/*",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf dist *.tsbuildinfo",
    "dev": "tsdown --watch",
    "prebuild": "pnpm run clean",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@dtf-interface/tsconfig": "workspace:*",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.3"
  },
  "keywords": [
    "dtf",
    "catalog",
    "yield-dtf",
    "index-dtf"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.19"
  },
  "publishConfig": {
    "access": "public"
  }
}
