{
  "name": "@reserve-protocol/dtf-rebalance-lib",
  "version": "3.2.1",
  "description": "Rebalancing library for DTFs in typescript",
  "keywords": [
    "npm",
    "package",
    "typescript"
  ],
  "homepage": "https://github.com/reserve-protocol/dtf-rebalance-lib#readme",
  "bugs": {
    "url": "https://github.com/reserve-protocol/dtf-rebalance-lib/issues"
  },
  "license": "BlueOak-1.0.0",
  "author": "Reserve Team",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reserve-protocol/dtf-rebalance-lib.git"
  },
  "files": [
    "dist",
    "LICENSE.md",
    "README.md"
  ],
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "compile": "hardhat compile",
    "build": "npm run clean && tsc --project tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "test": "npm run test:unit",
    "test:unit": "node --test --require ts-node/register --require tsconfig-paths/register test/**/unit.test.ts",
    "test:e2e": "hardhat test test/*.test.ts --bail",
    "typecheck": "tsc --project tsconfig.build.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "decimal.js-light": "^2.5.1",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.17",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "decimal.js-light": "^2.5.1"
  }
}
