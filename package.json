{
  "name": "dtf-interface",
  "version": "0.0.0",
  "private": true,
  "description": "TypeScript interface SDK for DTF integrations.",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "turbo run build",
    "clean": "turbo run clean",
    "dev": "turbo run dev",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "graphql:codegen": "pnpm --filter @dtf-interface/sdk graphql:codegen",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix --fix-suggestions --fix-dangerously",
    "playground:index": "pnpm --filter @dtf-interface/sdk playground:index",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "@changesets/config": "^3.1.4",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.63.0",
    "turbo": "^2.9.9",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
