{
  "name": "@reserve-protocol/react-sdk",
  "version": "0.1.4",
  "description": "React Query hooks for DTF interface integrations.",
  "keywords": [
    "dtf",
    "react",
    "sdk"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/reserve-protocol/dtf-interface",
    "directory": "packages/react-sdk"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf dist *.tsbuildinfo",
    "dev": "tsdown --watch",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@reserve-protocol/sdk": "workspace:*"
  },
  "devDependencies": {
    "@dtf-interface/tsconfig": "workspace:*",
    "@tanstack/react-query": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "react": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "viem": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.99.0",
    "react": "^18.3.0 || ^19.0.0",
    "viem": "^2.48.0"
  },
  "engines": {
    "node": ">=24"
  }
}
