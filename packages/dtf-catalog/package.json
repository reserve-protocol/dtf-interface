{
  "name": "@reserve-protocol/dtf-catalog",
  "version": "0.1.0",
  "description": "Curated DTF catalog for yield and index DTFs.",
  "keywords": [
    "catalog",
    "dtf",
    "index-dtf",
    "yield-dtf"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/reserve-protocol/dtf-interface",
    "directory": "packages/dtf-catalog"
  },
  "files": [
    "dist",
    "index-dtf",
    "yield-dtf",
    "images"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./images/*": "./images/*",
    "./index-dtf/*": "./index-dtf/*",
    "./yield-dtf/*": "./yield-dtf/*",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf dist *.tsbuildinfo",
    "dev": "tsdown --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@dtf-interface/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=24"
  }
}
